<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Состояние, когда апвоут поставлен (используем setSelected(true) в коде) -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#2000A8FF" />
            <stroke android:width="1dp" android:color="@color/accent_blue" />
        </shape>
    </item>
    <!-- Обычное состояние -->
    <item>
        <ripple android:color="#20FFFFFF">
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="#10FFFFFF" />
                    <stroke android:width="1dp" android:color="#20FFFFFF" />
                </shape>
            </item>
        </ripple>
    </item>
</selector>